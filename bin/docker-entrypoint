#!/bin/bash -e

# Enable jemalloc for reduced memory usage and latency.
if [ -z "${LD_PRELOAD+x}" ]; then
    LD_PRELOAD=$(find /usr/lib -name libjemalloc.so.2 -print -quit)
    export LD_PRELOAD
fi

# Prepare the production database before booting the web server.
if [ "${@: -2:1}" == "./bin/rails" ] && [ "${@: -1:1}" == "server" ]; then
    if ./bin/rails db:prepare && ./bin/rails db:seed; then
        echo "Database prepared and seeded"
    else
        echo "Database prepare/seed skipped; continuing boot"
    fi
fi

exec "${@}"
